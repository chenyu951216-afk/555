# Shared
PROJECT_NAME=crypto-backtest-record-system
TZ=Asia/Taipei

# PostgreSQL
POSTGRES_DB=backtest_records
POSTGRES_USER=backtest
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://backtest:change_me@postgres:5432/backtest_records

# API
API_HOST=0.0.0.0
API_PORT=8000
STORAGE_ROOT=/data/storage
MAX_UPLOAD_MB=200
BACKEND_CORS_ORIGINS=http://localhost:3000
DEFAULT_WORKSPACE_NAME=Personal
DEFAULT_USER_EMAIL=local@example.local
RECORD_START_AT=2026-05-08T00:00:00+08:00
ENFORCE_MINIMUM_RECORD_START=true
DEFAULT_TIMEZONE=Asia/Taipei

# Optional read-only Bitget import.
# Use API keys with read permission only. Do not enable trading permission for this system.
BITGET_API_BASE_URL=https://api.bitget.com
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
BITGET_LOCALE=en-US
BITGET_SYNC_LOOKBACK_DAYS=90

# Web
API_BASE_URL=http://localhost:8000/api
# Optional fallback for older deployments. Prefer API_BASE_URL for Zeabur.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
